	<Item class="Script" referent="RBX4603D5C673094ACCA18D1A49087F15D5">
		<Properties>
			<ProtectedString name="Source"><![CDATA[local ModulesMn = script:WaitForChild("VanishingM")
local VanishingM = require(ModulesMn)
local remotes = script.Vanish:Clone() ; remotes.Parent = game:GetService("ReplicatedStorage")

--in
VanishingM.Init(remotes)
require(script.LocalSide)()]]></ProtectedString>
			<bool name="Disabled">false</bool>
