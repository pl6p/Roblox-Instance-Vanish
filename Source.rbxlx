				<Item class="LocalScript" referent="RBX6CA1CB79310942D39A81D06FFBB2F0B9">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local vanishedPlayers = {}
game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin"):WaitForChild("Vanish"):WaitForChild("VanishONTURN"):WaitForChild("GiveTheVanish").OnClientEvent:Connect(function(plrname)
	local localPlayer = game:GetService("Players").LocalPlayer
	if plrname.Name == localPlayer.Name then
		warn("VAN! we dont destroyed yourself")
		return
	end
	if not vanishedPlayers[plrname] then
		vanishedPlayers[plrname] = {
			OriginalParent = plrname.Parent,
			PlayerInstance = plrname
		}
	end
	plrname.Parent = nil
	warn("VAN! Player " .. plrname.Name .. " destroyed")
end)
game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin"):WaitForChild("Vanish"):WaitForChild("VanishOFFTURN"):WaitForChild("GiveTheVanishFF").OnClientEvent:Connect(function(plrname)
	local localPlayer = game:GetService("Players").LocalPlayer
	if localPlayer.Name == plrname.Name then
		warn("VAN! dont creating yourself")
		return
	end
	if vanishedPlayers[plrname] then
		local playerData = vanishedPlayers[plrname]
		if playerData.OriginalParent then
			plrname.Parent = playerData.OriginalParent
			warn("VAN! plr " .. plrname.Name .. " created")
		end
		vanishedPlayers[plrname] = nil
	end
end)	]]></ProtectedString>
