				<Item class="Folder" referent="RBXC365A04D4756430FA34CB836AEF5E31B">
					<Properties>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">Vanish</string>
						<int64 name="SourceAssetId">-1</int64>
						<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
						<UniqueId name="UniqueId">2b89bb731c28f2f309e3fea100001f66</UniqueId>
					</Properties>
					<Item class="ModuleScript" referent="RBXD6CF4FCE5BE84AD5828697BF93D61F8C">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local VanishingM = {}
local vanishedPlayers = {}
local Players = game:GetService("Players")
local function GetVanishRemotes(CryMyAdmin)
	local Vanish = CryMyAdmin.Vanish
	local VanishONTURN = Vanish.VanishONTURN
	local VanishOFFTURN = Vanish.VanishOFFTURN
	return {
		SendToVanish = VanishONTURN.SendToVanish,
		SendToVanishFF = VanishOFFTURN.SendToVanishFF,
		GiveTheVanish = VanishONTURN.GiveTheVanish,
		GiveTheVanishFF = VanishOFFTURN.GiveTheVanishFF
	}
end
local function ValidateAdmin(plr, Whitelist)
	if Whitelist.Value and (not plr.Admin or not plr.Admin.Value) then
		plr:Kick("lol WHA?T .... whatcha doing")
		return false
	end
	return true
end
local function SetVanishState(plr, state, remotes, Whitelist)
	if not ValidateAdmin(plr, Whitelist) then return end
	vanishedPlayers[plr] = state or nil
	local action = state and "vanished" or "created"
	print(("VAN! Server %s %s"):format(action, plr.Name))
	local players = Players:GetPlayers()
	local remoteEvent = state and remotes.GiveTheVanish or remotes.GiveTheVanishFF
	for i = 1, #players do
		local player = players[i]
		if player ~= plr then
			remoteEvent:FireClient(player, plr)
		end
	end
end
function VanishingM.Init(CryMyAdmin, Whitelist)
	local remotes = GetVanishRemotes(CryMyAdmin)
	remotes.SendToVanish.OnServerEvent:Connect(function(plr)
		SetVanishState(plr, true, remotes, Whitelist)
	end)
	remotes.SendToVanishFF.OnServerEvent:Connect(function(plr)
		SetVanishState(plr, false, remotes, Whitelist)
	end)
	Players.PlayerAdded:Connect(function(newPlayer)
		for vanishedPlayer in pairs(vanishedPlayers) do
			if vanishedPlayer.Parent then
				remotes.GiveTheVanish:FireClient(newPlayer, vanishedPlayer)
			end
		end
	end)
	Players.PlayerRemoving:Connect(function(leavingPlayer)
		vanishedPlayers[leavingPlayer] = nil
	end)
end
function VanishingM.IsVanished(player)
	return vanishedPlayers[player] == true
end
function VanishingM.GetVanishedPlayers()
	local vanished = {}
	for player in pairs(vanishedPlayers) do
		if player.Parent then
			vanished[#vanished + 1] = player
		end
	end
	return vanished
end
return VanishingM]]></ProtectedString>
