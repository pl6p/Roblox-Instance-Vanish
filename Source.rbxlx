								<Item class="LocalScript" referent="RBX0F8FBF5D9D034C65AAAD99F96AF75549">
									<Properties>
										<ProtectedString name="Source"><![CDATA[local check = script.Parent.Parent.Enabled

local tempPlr = game:GetService("Players").LocalPlayer

--если пересоздатся персонаж игрока через LoadCharacter() то сделай print("rts")

script.Parent.MouseButton1Click:Connect(function()

	local currentCheck = script.Parent.Parent.Enabled.Value

	if currentCheck == false then
		script.Parent.Text = "God: Enabled"
		script.Parent.TextColor3 = Color3.fromRGB(67, 255, 95)
		local event1 = game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin"):WaitForChild("GOD"):WaitForChild("GavingGod")
		local plr = game:GetService("Players").LocalPlayer
		event1:FireServer(plr)
		script.Parent.Parent.Enabled.Value = true
	elseif currentCheck == true then
		script.Parent.Text = "God: Disabled"
		script.Parent.TextColor3 = Color3.fromRGB(255, 40, 12)
		local event = game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin"):WaitForChild("GOD"):WaitForChild("OFFingGod")
		local plr = game:GetService("Players").LocalPlayer
		event:FireServer(plr)
		script.Parent.Parent.Enabled.Value = false
	end
end)]]></ProtectedString>
