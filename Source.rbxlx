								<Item class="LocalScript" referent="RBX9157550FBCB14A939808F1968590372C">
									<Properties>
										<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer
local currentPercentage = 0

local heartbeatConnection = nil
local characterAddedConnection = nil

local function getPercentageValue()
	local percentageObject = script.Parent:FindFirstChild("Percentage")
	if percentageObject then
		if percentageObject:IsA("NumberValue") then
			return percentageObject.Value
		elseif percentageObject:IsA("TextLabel") or percentageObject:IsA("TextBox") then
			local num = tonumber(percentageObject.Text)
			return num or 0
		end
	end
	return 0
end

local function calculateTPWalkStrength(percentage)
	if percentage <= 0 then
		return 0
	end
	local baseStrength = math.min(percentage / 3, 1) 
	local extraStrength = math.max(0, (percentage - 3) / 10) 
	return baseStrength + extraStrength
end

local function setupTPWalk()
	-- Отключаем старое соединение, если оно есть
	if heartbeatConnection then
		heartbeatConnection:Disconnect()
		heartbeatConnection = nil
	end

	local character = localPlayer.Character
	if not character then
		return
	end

	local humanoid = character:WaitForChild("Humanoid")

	heartbeatConnection = RunService.Heartbeat:Connect(function(deltaTime)
		currentPercentage = getPercentageValue()
		local tpWalkStrength = calculateTPWalkStrength(currentPercentage)
		if tpWalkStrength <= 0 then
			return
		end

		-- Проверяем, существует ли ещё персонаж и PrimaryPart
		local currentCharacter = localPlayer.Character
		if not currentCharacter then
			return
		end

		local primaryPart = currentCharacter.PrimaryPart
		if not primaryPart then
			return
		end

		local currentHumanoid = currentCharacter:FindFirstChild("Humanoid")
		if not currentHumanoid then
			return
		end

		local moveDirection = currentHumanoid.MoveDirection
		if moveDirection.Magnitude > 0 then
			currentCharacter:SetPrimaryPartCFrame(
				primaryPart.CFrame + 
					moveDirection * deltaTime * tpWalkStrength * 30
			)
		end
	end)
end

-- Обработчик добавления персонажа
local function onCharacterAdded(character)
	setupTPWalk()
end

-- Начальная настройка
if localPlayer.Character then
	setupTPWalk()
end

-- Подписываемся на событие добавления персонажа
if characterAddedConnection then
	characterAddedConnection:Disconnect()
end
characterAddedConnection = localPlayer.CharacterAdded:Connect(onCharacterAdded)

-- Цикл обновления процента (лучше использовать RunService для этого)
while true do
	currentPercentage = getPercentageValue()
	task.wait(0.1)  -- task.wait() лучше чем wait()
end]]></ProtectedString>
