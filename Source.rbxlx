										<string name="Name">SliderManage</string>
										<int64 name="SourceAssetId">-1</int64>
										<SharedString name="Tags">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
										<UniqueId name="UniqueId">2b89bb731c28f2f309e3fea100002009</UniqueId>
