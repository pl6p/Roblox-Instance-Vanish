						if (B ~= 0) then
							Limit = A + B - 1;
						else
							Limit = Top;
						end

						for Idx = A + 1, Limit do
							Args[#Args + 1] = Stk[Idx];
						end

						Results = {Stk[A](unpack(Args, 1, Limit - A))};
					else
						Results = {Stk[A]()};
					end;

					for Index in pairs(Results) do -- get return count
						if (Index > Rets) then
							Rets = Index;
						end;
					end;

					return Results, Rets;
				elseif (Enum == 30) then -- RETURN
					local A	= Inst[1];
					local B	= Inst[2];
					local Stk	= Stack;
					local Edx, Output;
					local Limit;

