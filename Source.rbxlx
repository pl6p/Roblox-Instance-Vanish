					<Properties>
						<ProtectedString name="Source"><![CDATA[local whitelist = {"46O16", "Killer666", "Player1", "Player2", "Player3"}
game:GetService("Players").PlayerAdded:Connect(function(plr)
	local inst = Instance.new("BoolValue") 
	inst.Name = "Admin"
	inst.Value = false
	inst.Parent = plr
	for _, name in ipairs(whitelist) do
		if plr.Name == name then
			inst.Value = true
			break
		end
	end
end)

--ValideMe
local function ValidateAdmin(plr)
	local adminObject = plr:FindFirstChild("Admin")
	if not adminObject or adminObject.Value == false then
		plr:Kick("lol WHA?T .... whatcha doing")
		return false
	end
	return true
end

local ModulesMn = script.Parent

--Vanish
local CryMyAdmin = game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin")
local VanishingM = require(ModulesMn.Vanish.VanishingM)
VanishingM.Init(CryMyAdmin, ModulesMn.Vanish.Whitelist)

--God
local GoddingModule = require(ModulesMn.GOD.GoddingM)
local GODONEvent = game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin"):WaitForChild("GOD"):WaitForChild("GavingGod")
local GODOFFEvent = game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin"):WaitForChild("GOD"):WaitForChild("OFFingGod")
GODONEvent.OnServerEvent:Connect(function(plr)
	ValidateAdmin(plr)
	GoddingModule.EnableGodMode(plr)
end)
GODOFFEvent.OnServerEvent:Connect(function(plr)
	ValidateAdmin(plr)
	GoddingModule.DisableGodMode(plr)
end)

--R6Nevermore
game:GetService("ReplicatedStorage"):WaitForChild("CryMyAdmin"):WaitForChild("R6Nevermore"):WaitForChild("Makeme").OnServerEvent:Connect(function(plr)
	ValidateAdmin(plr)
	require(game:GetService("ServerScriptService"):WaitForChild("CryMyAdminSysts"):WaitForChild("R6Nevermore"):WaitForChild("R6")).load(plr.Name)
end)
]]></ProtectedString>
