								<Item class="LocalScript" referent="RBXF067C7DD77DA4069B704CDAF82D4A006">
									<Properties>
										<ProtectedString name="Source"><![CDATA[local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Dragging = false
local lastSentValue = nil
local lastSentTime = 0
local sendCount = 0
local function TweenSlider(position, value)
	local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local positionTween = TweenService:Create(script.Parent.TextButton, tweenInfo, {Position = position})
	local valueTween = TweenService:Create(script.Parent.Percentage, tweenInfo, {Value = value})
	positionTween:Play()
	valueTween:Play()
	script.Parent.ShowingCurrent.Text = string.format("%.1f", value)
	local currentTime = tick()
	if lastSentValue == value then
		if currentTime - lastSentTime < 1 then
			sendCount = sendCount + 1
			if sendCount > 3 then
				return
			end
		else
			sendCount = 1
		end
	else
		sendCount = 1
	end
	lastSentValue = value
	lastSentTime = currentTime
	local plr = game:GetService("Players").LocalPlayer
end
script.Parent.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		Dragging = true
		local MousePos = UIS:GetMouseLocation() + Vector2.new(0, -36)
		local RelPos = MousePos - script.Parent.AbsolutePosition
		local Percent = math.clamp(RelPos.X / script.Parent.AbsoluteSize.X, 0, 1)
		local FinalValue = ChangeToValue(Percent)

		TweenSlider(UDim2.new(Percent, 0, script.Parent.TextButton.Position.Y.Scale, 0), FinalValue)
	end
end)
script.Parent.TextButton.MouseButton1Down:Connect(function()
	Dragging = true
end)

function ChangeToValue(Percent)
	local Value = math.floor(Percent * 100) / 10
	return math.clamp(Value, 0, 10)
end
UIS.InputChanged:Connect(function()
	if Dragging then
		local MousePos = UIS:GetMouseLocation() + Vector2.new(0, -36)
		local RelPos = MousePos - script.Parent.AbsolutePosition
		local Percent = math.clamp(RelPos.X / script.Parent.AbsoluteSize.X, 0, 1)
		local FinalValue = ChangeToValue(Percent)

		TweenSlider(UDim2.new(Percent, 0, script.Parent.TextButton.Position.Y.Scale, 0), FinalValue)
	end
end)
UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		Dragging = false
	end
end)]]></ProtectedString>
