					<Item class="LocalScript" referent="RBXA4714C70FC9A46118E5C5FB7913D84A9">
						<Properties>
							<ProtectedString name="Source"><![CDATA[local check = script.Parent.Parent.Enabled
script.Parent.MouseButton1Click:Connect(function()
	local currentCheck = script.Parent.Parent.Enabled.Value
	if currentCheck == false then
		script.Parent.Text = "Vanish: Enabled"
		script.Parent.TextColor3 = Color3.fromRGB(67, 255, 95)
		local event = game:GetService("ReplicatedStorage"):WaitForChild("Vanish"):WaitForChild("SendToVanish")
		local plr = game:GetService("Players").LocalPlayer
		local plrname = game:GetService("Players").LocalPlayer.Name
		event:FireServer(plrname, "lol")
		script.Parent.Parent.Enabled.Value = true
	elseif currentCheck == true then
		script.Parent.Text = "Vanish: Disabled"
		script.Parent.TextColor3 = Color3.fromRGB(255, 40, 12)
		local event = game:GetService("ReplicatedStorage"):WaitForChild("Vanish"):WaitForChild("SendToVanishFF")
		local plr = game:GetService("Players").LocalPlayer
		local plrname = game:GetService("Players").LocalPlayer.Name
		event:FireServer(plrname, "lol")
		script.Parent.Parent.Enabled.Value = false
	end
end)]]></ProtectedString>
