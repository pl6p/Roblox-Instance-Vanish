							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local GoddingModule = {}
local playerConnections = {}
local fallProtectionParts = {}
local originalJoints = {}

local function ValidateAdmin(plr)
	local adminObject = plr:FindFirstChild("Admin")
	if not adminObject or adminObject.Value == false then
		plr:Kick("lol WHA?T .... whatcha doing")
		return false
	end
	return true
end

local function createGodValue(plr)
	local isGod = plr:FindFirstChild("IsGod")
	if not isGod then
		isGod = Instance.new("BoolValue")
		isGod.Name = "IsGod"
		isGod.Value = false
		isGod.Parent = plr
	end
	return isGod
end

local function backupJoints(character)
	if not character then return end

	originalJoints[character] = {}

	for _, joint in ipairs(character:GetDescendants()) do
		if joint:IsA("Motor6D") or joint:IsA("Weld") or joint:IsA("WeldConstraint") then
			originalJoints[character][joint] = {
				Part0 = joint.Part0,
				Part1 = joint.Part1,
				C0 = joint.C0,
				C1 = joint.C1,
				Enabled = joint.Enabled,
				Name = joint.Name,
				ClassName = joint.ClassName
			}
		end
	end
end

local function restoreJoints(character)
	if not character or not originalJoints[character] then return end

	for joint, properties in pairs(originalJoints[character]) do
		if not joint or joint.Parent == nil then
			local newJoint = Instance.new(properties.ClassName)
			newJoint.Part0 = properties.Part0
			newJoint.Part1 = properties.Part1
			newJoint.C0 = properties.C0
			newJoint.C1 = properties.C1
			newJoint.Enabled = properties.Enabled
			newJoint.Name = properties.Name
			newJoint.Parent = character
		elseif joint.Parent then
			joint.Part0 = properties.Part0
			joint.Part1 = properties.Part1
			joint.C0 = properties.C0
			joint.C1 = properties.C1
			joint.Enabled = true
		end
	end
end

local function protectJoints(character)
	if not character then return end

	local jointProtectionConnection
	jointProtectionConnection = game:GetService("RunService").Heartbeat:Connect(function()
		if character and character.Parent then
			restoreJoints(character)

			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.Anchored = false
					part.Locked = true

					if part:FindFirstChildOfClass("Motor6D") or part:FindFirstChildOfClass("Weld") then
						for _, joint in ipairs(part:GetChildren()) do
							if joint:IsA("Motor6D") or joint:IsA("Weld") then
								joint.Enabled = true
							end
						end
					end
				end
			end
		else
			jointProtectionConnection:Disconnect()
		end
	end)

	return jointProtectionConnection
end

local function createFallProtection(character)
	if not character then return end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	if fallProtectionParts[character] then
		fallProtectionParts[character]:Destroy()
	end

	local floatPart = Instance.new("Part")
	floatPart.Name = "IY_FGodFallProtection"
	floatPart.Transparency = 1
	floatPart.Size = Vector3.new(50, 1000, 50)
	floatPart.Anchored = true
	floatPart.Locked = true
	floatPart.CanCollide = false
	floatPart.Parent = character

	fallProtectionParts[character] = floatPart

	local fallProtectionConnection
	fallProtectionConnection = game:GetService("RunService").Heartbeat:Connect(function()
		if character and character.Parent and rootPart and rootPart.Parent then
			floatPart.Position = Vector3.new(
				rootPart.Position.X,
				workspace.FallenPartsDestroyHeight - 494.5,
				rootPart.Position.Z
			)
		else
			fallProtectionConnection:Disconnect()
		end
	end)

	return fallProtectionConnection
end

local function applyCompleteInvulnerability(character)
	if not character or character.Parent == nil then return end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	backupJoints(character)

	local existingFF = character:FindFirstChild("ffgod")
	if not existingFF then
		local ff = Instance.new("ForceField")
		ff.Name = "ffgod"
		ff.Visible = false
		ff.Parent = character
	end

	humanoid.HealthDisplayDistance = 0
	humanoid.MaxHealth = math.huge
	humanoid.Health = math.huge
	humanoid.BreakJointsOnDeath = false
	humanoid.PlatformStand = false

	local fallProtectionConnection = createFallProtection(character)
	local jointProtectionConnection = protectJoints(character)

	local healthConnection = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
		humanoid.Health = math.huge
	end)

	local stateConnection = humanoid.StateChanged:Connect(function(oldState, newState)
		if newState == Enum.HumanoidStateType.Dead then
			humanoid.Health = math.huge
			task.wait(0.05)
			humanoid:ChangeState(Enum.HumanoidStateType.Running)
		end
	end)

	for _, part in ipairs(character:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanTouch = false
			part.CanQuery = false
			part.Locked = true
		end
	end

	playerConnections[character] = {
		health = healthConnection,
		state = stateConnection,
		fallProtection = fallProtectionConnection,
		jointProtection = jointProtectionConnection
	}
end

local function removeCompleteInvulnerability(character)
	if not character then return end

	if fallProtectionParts[character] then
		fallProtectionParts[character]:Destroy()
		fallProtectionParts[character] = nil
	end

	if originalJoints[character] then
		originalJoints[character] = nil
	end

	for _, item in ipairs(character:GetDescendants()) do
		if item.Name == "ffgod" then
			item:Destroy()
		end
		if item:IsA("BasePart") then
			item.CanTouch = true
			item.CanQuery = true
			item.Locked = false
		end
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid.HealthDisplayDistance = 100
		humanoid.MaxHealth = 100
		humanoid.Health = math.min(humanoid.Health, 100)
		humanoid.BreakJointsOnDeath = true
	end

	if playerConnections[character] then
		for _, connection in pairs(playerConnections[character]) do
			if connection then
				connection:Disconnect()
			end
		end
		playerConnections[character] = nil
	end
end

function GoddingModule.EnableGodMode(plr)
	if not ValidateAdmin(plr) then return false end

	local isGod = createGodValue(plr)
	isGod.Value = true

	local function onCharacterAdded(character)
		if isGod.Value then
			task.wait(0.1)
			if character and character.Parent ~= nil then
				applyCompleteInvulnerability(character)
			end
		end
	end

	if plr.Character then
		applyCompleteInvulnerability(plr.Character)
	end

	if not playerConnections[plr] then
		playerConnections[plr] = {}
	end

	if playerConnections[plr].characterAdded then
		playerConnections[plr].characterAdded:Disconnect()
	end

	playerConnections[plr].characterAdded = plr.CharacterAdded:Connect(onCharacterAdded)

	print("GoDding " .. plr.Name)
	return true
end

function GoddingModule.DisableGodMode(plr)
	if not ValidateAdmin(plr) then return false end

	local isGod = plr:FindFirstChild("IsGod")
	if isGod then
		isGod.Value = false
	end

	if plr.Character then
		removeCompleteInvulnerability(plr.Character)
	end

	if playerConnections[plr] then
		if playerConnections[plr].characterAdded then
			playerConnections[plr].characterAdded:Disconnect()
		end
		playerConnections[plr] = nil
	end

	warn("UNGoDding " .. plr.Name)
	return true
end

game.Players.PlayerRemoving:Connect(function(plr)
	if playerConnections[plr] then
		GoddingModule.DisableGodMode(plr)
	end
end)

return GoddingModule]]></ProtectedString>
