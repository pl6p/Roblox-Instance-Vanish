						<Item class="LocalScript" referent="RBX06ED7EF6B602448FBF44FE6321D8EB52">
							<Properties>
								<ProtectedString name="Source"><![CDATA[local path = script.Parent.Parent.Parent.Parent.Rooms
local Parent = script.Parent
local Char = Parent.Character
local Fun = Parent.FunButton
local PlayersB = Parent.Players
local ScrExec = Parent.ScriptExecution
local ServerB = Parent.Server
local uiB = Parent.UIButton
local roomNames = {
	Character = "Character",
	Server = "Server", 
	Players = "Players",
	UIButton = "UI",
	FunButton = "Fun",
	ScriptExecution = "Scripting"
}
local function showOnlyOneRoom(button)
	local roomName = button.Name .. "Room"
	local targetRoom = path:FindFirstChild(roomName)
	if not targetRoom then
		return
	end
	for _, room in pairs(path:GetChildren()) do
		if (room:IsA("Frame") or room:IsA("ScrollingFrame") or room:IsA("CanvasGroup")) and room.Name ~= "Background" and room.Name ~= "TitleOfRoom" then
			room.Visible = false
		end
	end
	targetRoom.Visible = true
	local title = path:FindFirstChild("TitleOfRoom")
	if title and title:IsA("TextLabel") then
		title.Text = roomNames[button.Name] or roomName
	end
end
for _, child in pairs(Parent:GetChildren()) do
	if child:IsA("TextButton") or child:IsA("ImageButton") then
		child.MouseButton1Click:Connect(function()
			showOnlyOneRoom(child)
		end)
	end
end
local function hideAllRooms()
	for _, room in pairs(path:GetChildren()) do
		if (room:IsA("Frame") or room:IsA("ScrollingFrame") or room:IsA("CanvasGroup")) and room.Name ~= "Background" and room.Name ~= "TitleOfRoom" then
			room.Visible = false
		end
	end
end]]></ProtectedString>
