						</Properties>
					</Item>
					<Item class="BoolValue" referent="RBXF9A3C723CAE94172B557A8366E61010C">
						<Properties>
							<bool name="Value">true</bool>
							<BinaryString name="AttributesSerialize"></BinaryString>
