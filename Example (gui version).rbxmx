					<Properties>
						<ProtectedString name="Source"><![CDATA[local plrname = game:GetService("Players").LocalPlayer.Name
local remotes = game:GetService("ReplicatedStorage"):WaitForChild("Vanish")
local GiveTheVanish = remotes:WaitForChild("GiveTheVanish")
local GiveTheVanishFF = remotes:WaitForChild("GiveTheVanishFF")
