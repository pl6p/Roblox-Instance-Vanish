						<Item class="LocalScript" referent="RBX80856F6C4E524C7F9EE8983CBD6F4AD8">
							<Properties>
								<ProtectedString name="Source"><![CDATA[local VanishedPlrs = {}
local Vanish = game:GetService("ReplicatedStorage"):WaitForChild("Vanish")
local SendToVanish = Vanish.SendToVanish
local SendToVanishFF = Vanish.SendToVanishFF
local GiveTheVanish = Vanish.GiveTheVanish
local GiveTheVanishFF = Vanish.GiveTheVanishFF


GiveTheVanish.OnClientEvent:Connect(function(plrname)
	local localplr = game:GetService("Players").localplr
	if plrname.Name == localplr.Name then
		--warn("VAN! we dont destroyed yourself")
		return
	end
	if not VanishedPlrs[plrname] then
		VanishedPlrs[plrname] = {
			OrigParent = plrname.Parent,
			PlayerInstance = plrname
		}
	end
	plrname.Parent = nil
	--warn("VAN! Player " .. plrname.Name .. " destroyed")
end)
GiveTheVanishFF.OnClientEvent:Connect(function(plrname)
	local localplr = game:GetService("Players").localplr
	if localplr.Name == plrname.Name then
		--warn("VAN! dont creating yourself")
		return
	end
	if VanishedPlrs[plrname] then
		local playerData = VanishedPlrs[plrname]
		if playerData.OrigParent then
			plrname.Parent = playerData.OrigParent
			--warn("VAN! plr " .. plrname.Name .. " created")
		end
		VanishedPlrs[plrname] = nil
	end
end)	]]></ProtectedString>
