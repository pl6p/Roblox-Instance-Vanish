				</Properties>
				<Item class="ModuleScript" referent="RBXB84D7F7179F94CEEA03658172091D57D">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local VanishingM = {}
local VanedPlrs = {}
local Players = game:GetService("Players")
local function GetVanishRemotes(remotes)
	local Vanish = remotes
	return {
		SendToVanish = Vanish.SendToVanish,
		SendToVanishFF = Vanish.SendToVanishFF,
		GiveTheVanish = Vanish.GiveTheVanish,
		GiveTheVanishFF = Vanish.GiveTheVanishFF
	}
end

local function SetVanishState(plr, state, remotes)
	VanedPlrs[plr] = state or nil
	local action = state and "vanished" or "created"
	--print(("VAN! Server %s %s"):format(action, plr.Name))
	local players = Players:GetPlayers()
	local remoteEvent = state and remotes.GiveTheVanish or remotes.GiveTheVanishFF
	for i = 1, #players do
		local player = players[i]
		if player ~= plr then
			remoteEvent:FireClient(player, plr)
		end
	end
end

function VanishingM.Init(Vanish)
	local remotes = GetVanishRemotes(Vanish)
	remotes.SendToVanish.OnServerEvent:Connect(function(plr)
		SetVanishState(plr, true, remotes)
	end)
	remotes.SendToVanishFF.OnServerEvent:Connect(function(plr)
		SetVanishState(plr, false, remotes)
	end)
	Players.PlayerAdded:Connect(function(NewPlr)
		for VanedPlr in pairs(VanedPlrs) do
			if VanedPlr.Parent then
				remotes.GiveTheVanish:FireClient(NewPlr, VanedPlr)
			end
		end
	end)
	Players.PlayerRemoving:Connect(function(LeavinPLR)
		VanedPlrs[LeavinPLR] = nil
	end)
end

function VanishingM.IsVanished(player)
	return VanedPlrs[player] == true
end

function VanishingM.GetVanedPlrs()
	local vanished = {}
	for player in pairs(VanedPlrs) do
		if player.Parent then
			vanished[#vanished + 1] = player
		end
	end
	return vanished
end

return VanishingM]]></ProtectedString>
